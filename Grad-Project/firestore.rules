rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All authenticated users retain full access (existing app behavior)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Check-in page (unauthenticated scanner) — read-only on lookup collections
    match /eventRegistrations/{regId} {
      allow read: if true;
      // Allow marking checkedIn only — no other field changes
      allow update: if request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['checkedIn', 'checkedInAt']);
    }

    match /events/{eventId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if true;
    }

    match /eventFeedback/{docId} {
      allow read: if true;
    }
  }
}
